# ---------------------------------------------------------------------------
# ozaki-rsv-nextjs 環境変数サンプル
# このファイルをコピーして .env を作成してください:  cp .env.example .env
# .env 自体は .gitignore 済み(コミットしない)。ここには秘密情報を書かず、
# 変数名と開発用ダミー値のみを記載する。
# ---------------------------------------------------------------------------

# --- Database ---
# 土台 PR では docker-compose.yml を移植していないため、各自のローカル DB に合わせて設定する。
DATABASE_URL="postgresql://ozaki:ozaki_dev_password@localhost:5432/ozaki_rsv?schema=public"

# --- 開発用テスト管理者アカウント (prisma/seed.ts で投入) ---
# username: admin  /  role: ADMIN
# ※ パスワードは seed 実行時に bcrypt でハッシュ化して保存される(平文は保存されない)。
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="password123"

# ===========================================================================
# 以下は後続の US で実装される機能が参照する変数の一覧(土台 PR では未使用)。
# 値はコミットせず、各自の .env にのみ実値を設定すること。
# ===========================================================================

# --- Auth.js (NextAuth v5) ※ 認証は US-005 で実装 ---
# 必ず `openssl rand -base64 32` 等で生成した独自の値を .env に設定すること(ここには置かない)。
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- メール送信 (nodemailer) ※ 実送信は後続タスクで実装 ---
MAIL_HOST="localhost"
MAIL_PORT="1025"
MAIL_SECURE="false"
MAIL_USER=""
MAIL_PASSWORD=""
MAIL_FROM="noreply@example.com"
# 業務要件として継続必須の Bcc 宛先(要件 3-5)。本番では実アドレスを .env に設定する。
MAIL_BCC="reservation-bcc@example.com"
MAIL_SUBJECT="ご予約ありがとうございます"

# --- 店舗電話番号(メール本文のキャンセル案内に使用) ---
# 本番投入前に実際の番号へ差し替えること(要確認事項)。
STORE_TEL_HYUGA="0982-XX-XXXX"
STORE_TEL_NOBEOKA="0982-YY-YYYY"
