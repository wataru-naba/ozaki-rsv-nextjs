# ---------------------------------------------------------------------------
# ozaki-rsv-nextjs 環境変数サンプル
# このファイルをコピーして .env を作成してください:  cp .env.example .env
# .env 自体は .gitignore 済み(コミットしない)。ここには開発用のダミー値のみ記載する。
# ---------------------------------------------------------------------------

# --- Database (docker-compose.yml の値と一致させること) ---
DATABASE_URL="postgresql://ozaki:ozaki_dev_password@localhost:5432/ozaki_rsv?schema=public"

# --- Auth.js (NextAuth v5) ---
# 本番では必ず `openssl rand -base64 32` 等で生成した独自の値に差し替えること。
AUTH_SECRET="xfPfAARVEW88A3kMENg/lSLZGK87hZicAM7CsQtSt2E="
# 開発サーバーの URL(NextAuth v5 の trustHost 利用時は任意)
AUTH_URL="http://localhost:3000"

# --- 開発用テスト管理者アカウント (prisma/seed.ts で投入) ---
# username: admin  /  password: password123  /  role: ADMIN
# ※ パスワードは seed 実行時に bcrypt でハッシュ化して保存される。平文はここに記載のもの。
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="password123"

# --- メール送信 (nodemailer) ※ 基盤フェーズではダミー値。実送信は後続タスクで実装 ---
MAIL_HOST="localhost"
MAIL_PORT="1025"
MAIL_SECURE="false"
MAIL_USER=""
MAIL_PASSWORD=""
MAIL_FROM="noreply@example.com"
# 業務要件として継続必須の Bcc 宛先(要件 3-5)。本番では実アドレスを設定する。
MAIL_BCC="wataru.kawano@taslink.co.jp"
MAIL_SUBJECT="ご予約ありがとうございます"
